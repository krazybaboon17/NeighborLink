# Taskfy — Local environment variables
# Copy this file to `.env` and fill in the values for your own Lovable Cloud / Supabase project.
# These are PUBLIC client-side values (safe to expose). Server-side secrets live in Lovable Cloud → Secrets.

# Lovable Cloud (Supabase) public credentials
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-PUBLISHABLE-ANON-KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# --- Server-side only (NOT prefixed with VITE_) ---
# These never go in this file; configure them in Lovable Cloud → Project Settings → Secrets.
#   LOVABLE_API_KEY              # for AI gateway (chat, recommendations, moderation, face verification)
#   SUPABASE_SERVICE_ROLE_KEY    # auto-provisioned, used by edge functions
#   SUPABASE_URL                 # auto-provisioned
